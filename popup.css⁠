const { createFFmpeg, fetchFile } = FFmpeg;

// Initiera FFmpeg
const ffmpeg = createFFmpeg({
  corePath: '/ffmpeg/ffmpeg-core.js',
  log: true,
});

const fileInput = document.getElementById('file-input');
const browseBtn = document.getElementById('browse-btn');
const uploadContent = document.getElementById('upload-content');
const processingState = document.getElementById('processing-state');
const successState = document.getElementById('success-state');
const statusText = document.getElementById('status-text');
const progressBar = document.getElementById('progress-bar');
const downloadBtn = document.getElementById('download-btn');

// Starta motorn direkt när sidan laddas
async function initFFmpeg() {
  try {
    if (!ffmpeg.isLoaded()) {
      statusText.innerText = "Initializing engine...";
      await ffmpeg.load();
      console.log("FFmpeg ready");
    }
  } catch (err) {
    console.error(err);
    statusText.innerText = "Error loading engine";
    alert("Kunde inte ladda FFmpeg: " + err.message);
  }
}
initFFmpeg();

// Hantera klick på "Browse"
browseBtn.addEventListener('click', () => fileInput.click());

// Hantera filval
fileInput.addEventListener('change', async (e) => {
  const file = e.target.files[0];
  if (!file) return;

  // Visa processing-läge
  uploadContent.classList.add('hidden');
  processingState.classList.remove('hidden');
  statusText.innerText = "Processing video...";

  try {
    // Skriv fil till minnet
    ffmpeg.FS('writeFile', 'input.mp4', await fetchFile(file));

    // Kör FFmpeg-kommando (exempel: kopiera utan omkodning för att behålla kvalitet)
    await ffmpeg.run('-i', 'input.mp4', '-c', 'copy', 'output.mp4');

    // Hämta resultatet
    const data = ffmpeg.FS('readFile', 'output.mp4');
    
    // Skapa nedladdningslänk
    const url = URL.createObjectURL(new Blob([data.buffer], { type: 'video/mp4' }));
    downloadBtn.onclick = () => {
      const a = document.createElement('a');
      a.href = url;
      a.download = 'patched-video.mp4';
      a.click();
    };

    // Visa success-läge
    processingState.classList.add('hidden');
    successState.classList.remove('hidden');
    progressBar.style.width = '100%';

  } catch (err) {
    console.error(err);
    statusText.innerText = "Error processing video";
    alert("Något gick fel: " + err.message);
  }
});
